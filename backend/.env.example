# Copy to .env and fill in real values where noted.

# Google OAuth — Lars creates the client in Google Cloud Console and pastes the
# values here. Authorized redirect URI must include OAUTH_REDIRECT_URI below.
GOOGLE_CLIENT_ID=PLACEHOLDER_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=PLACEHOLDER_GOOGLE_CLIENT_SECRET
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Session cookie signing secret — change to a random value.
SESSION_SECRET=dev-insecure-change-me

# Where the browser is sent after login.
FRONTEND_URL=http://localhost:5173

# DB connection. For `docker compose up` this is overridden to host "db".
# For running uvicorn directly on the host, this localhost value is used.
DATABASE_URL=postgresql+psycopg://eventradar:eventradar@localhost:5432/eventradar

# Web Push (VAPID). Generate a keypair once with `vapid --gen` (py-vapid, ships with pywebpush)
# and paste the values here — do NOT commit real keys. The public key is also exposed to the
# frontend so the browser can subscribe. Subject is a mailto:/https: contact for push services.
# Leave empty to keep push delivery disabled (send_push is a no-op).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:comflock@gmail.com
